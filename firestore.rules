rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 分類：顧客可讀，登入者可寫
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 商品：顧客可讀，登入者可寫
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 訂單：顧客可新增，登入者可讀寫刪
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;

      // 訂單細項（子集合）
      match /items/{itemId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null;
      }
    }
  }
}
